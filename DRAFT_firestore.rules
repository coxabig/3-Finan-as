rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives & Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isEmailVerified() && request.auth.uid == userId;
    }

    // Relational sync helper: verify user belongs to the couple
    function isMemberOfCouple(coupleId) {
      return isEmailVerified() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('coupleId', 'none') == coupleId;
    }

    // --- ENTITY VALIDATORS (Antigravity Hardened) ---

    function isValidUser(data) {
      let required = ['email', 'createdAt', 'uid'];
      let optional = ['displayName', 'photoURL', 'revenue', 'coupleId', 'onboarded', 'isPremium', 'darkMode', 'updatedAt', 'userColor', 'partnerColor'];
      let all = required.concat(optional);
      
      return data.keys().hasAll(required) &&
             data.keys().hasOnly(all) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128) &&
             (data.get('revenue', 0) is number) &&
             (data.get('onboarded', false) is bool) &&
             (data.get('isPremium', false) is bool) &&
             (data.get('darkMode', false) is bool) &&
             data.createdAt is timestamp;
    }

    function isValidCouple(data) {
      let required = ['user1', 'user2', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(required) &&
             data.keys().hasOnly(required) &&
             isValidId(data.user1) &&
             (data.user2 == null || isValidId(data.user2)) &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidTransaction(data) {
      let required = ['description', 'amount', 'type', 'ownerId', 'createdAt', 'month', 'date', 'frequency', 'responsibility'];
      let optional = ['installments', 'installmentIndex', 'parentId', 'category', 'updatedAt', 'cardId', 'startInstallmentIndex', 'desc'];
      let all = required.concat(optional);

      return data.keys().hasAll(required) &&
             data.keys().hasOnly(all) &&
             data.description is string && data.description.size() <= 400 && // Slightly larger for safety
             data.amount is number &&
             data.type in ['revenue', 'expense'] &&
             data.ownerId == request.auth.uid &&
             data.month is string && data.month.matches('^[0-9]{4}-[0-9]{2}$') &&
             data.createdAt is timestamp &&
             (data.get('category', '') is string && data.get('category', '').size() <= 64) &&
             (data.get('frequency', '') in ['once', 'fixed', 'installments']);
    }

    function isValidGoal(data) {
      let required = ['title', 'targetAmount', 'currentAmount', 'coupleId', 'createdAt'];
      let optional = ['deadline', 'type', 'updatedAt'];
      let all = required.concat(optional);

      return data.keys().hasAll(required) &&
             data.keys().hasOnly(all) &&
             data.title is string && data.title.size() <= 128 &&
             data.targetAmount is number &&
             data.currentAmount is number &&
             data.coupleId is string &&
             data.createdAt is timestamp;
    }

    function isValidCard(data) {
      let required = ['name', 'lastDigits', 'limit', 'ownerId', 'createdAt'];
      let optional = ['updatedAt', 'color'];
      let all = required.concat(optional);

      return data.keys().hasAll(required) &&
             data.keys().hasOnly(all) &&
             data.name is string && data.name.size() <= 128 &&
             data.lastDigits is string && data.lastDigits.size() == 4 &&
             data.limit is number &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      let required = ['name', 'color', 'coupleId', 'createdAt'];
      let optional = ['updatedAt', 'iconName'];
      let all = required.concat(optional);

      return data.keys().hasAll(required) &&
             data.keys().hasOnly(all) &&
             data.name is string && data.name.size() <= 64 &&
             data.color is string && data.color.size() <= 32 &&
             data.coupleId is string &&
             data.createdAt is timestamp;
    }

    // --- ROUTES ---

    // USERS: Strictly isolated PII
    match /users/{userId} {
      allow read: if isEmailVerified() && (
        isOwner(userId) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('coupleId', 'none') == resource.data.get('coupleId', 'null')
      );
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    (
                      // Tiered updates: Owner can change profile but not administrative tags like 'isAdmin' if we had them
                      incoming().diff(existing()).affectedKeys().hasOnly(['revenue', 'displayName', 'photoURL', 'coupleId', 'onboarded', 'isPremium', 'darkMode', 'updatedAt', 'userColor', 'partnerColor'])
                    );
    }

    // COUPLES: The Master Resource
    match /couples/{coupleId} {
      allow get: if isEmailVerified();
      allow list: if isEmailVerified() && (
        resource.data.user1 == request.auth.uid || 
        resource.data.user2 == request.auth.uid
      );
      allow create: if isEmailVerified() && 
                    incoming().user1 == request.auth.uid && 
                    isValidCouple(incoming());
      
      allow update: if isEmailVerified() && (
        // Action: Join Couple
        (existing().user2 == null && 
         incoming().user2 == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['user2', 'updatedAt']) &&
         incoming().updatedAt == request.time) ||
        // Action: General heartbeat (only members)
        ((existing().user1 == request.auth.uid || existing().user2 == request.auth.uid) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']) &&
         incoming().updatedAt == request.time)
      );
    }

    // SUBCOLLECTIONS: Protected by Relational Invariant
    match /couples/{coupleId}/transactions/{txId} {
      allow read, delete: if isMemberOfCouple(coupleId);
      allow create: if isMemberOfCouple(coupleId) && isValidTransaction(incoming()) && incoming().createdAt == request.time;
      allow update: if isMemberOfCouple(coupleId) && 
                    isValidTransaction(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().ownerId == existing().ownerId &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'type', 'month', 'date', 'frequency', 'responsibility', 'installments', 'installmentIndex', 'parentId', 'category', 'updatedAt', 'cardId', 'startInstallmentIndex', 'desc'])
                    );
    }

    match /couples/{coupleId}/goals/{goalId} {
      allow read, delete: if isMemberOfCouple(coupleId);
      allow create: if isMemberOfCouple(coupleId) && isValidGoal(incoming()) && incoming().createdAt == request.time;
      allow update: if isMemberOfCouple(coupleId) && 
                    isValidGoal(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().coupleId == existing().coupleId &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'targetAmount', 'currentAmount', 'deadline', 'type', 'updatedAt'])
                    );
    }

    match /couples/{coupleId}/cards/{cardId} {
      allow read, delete: if isMemberOfCouple(coupleId);
      allow create: if isMemberOfCouple(coupleId) && isValidCard(incoming()) && incoming().createdAt == request.time;
      allow update: if isMemberOfCouple(coupleId) && 
                    isValidCard(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().ownerId == existing().ownerId &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastDigits', 'limit', 'color', 'updatedAt'])
                    );
    }

    match /couples/{coupleId}/categories/{catId} {
      allow read, delete: if isMemberOfCouple(coupleId);
      allow create: if isMemberOfCouple(coupleId) && isValidCategory(incoming()) && incoming().createdAt == request.time;
      allow update: if isMemberOfCouple(coupleId) && 
                    isValidCategory(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().coupleId == existing().coupleId &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'color', 'iconName', 'updatedAt'])
                    );
    }
  }
}
