rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOfCouple(coupleId) {
      let couple = get(/databases/$(database)/documents/couples/$(coupleId)).data;
      return isSignedIn() && (couple.user1 == request.auth.uid || couple.user2 == request.auth.uid);
    }

    // 27: Connectivity test
    match /system/connectivity_test {
      allow read: if true;
    }

    // --- ENTITY VALIDATORS ---

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'photoURL', 'revenue', 'createdAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.revenue is number &&
             data.createdAt == request.time;
    }

    function isValidCouple(data) {
      return data.keys().hasAll(['user1', 'user2', 'createdAt', 'updatedAt']) &&
             isValidId(data.user1) &&
             (data.user2 == null || isValidId(data.user2)) &&
             data.createdAt == request.time;
    }

    function isValidTransaction(data) {
      let requiredFields = ['description', 'amount', 'type', 'ownerId', 'createdAt', 'month', 'date', 'frequency', 'responsibility'];
      let optionalFields = ['installments', 'installmentIndex', 'parentId'];
      let allFields = requiredFields.concat(optionalFields);
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allFields) &&
             data.description is string && data.description.size() <= 200 &&
             data.amount is number &&
             data.type in ['revenue', 'expense'] &&
             isValidId(data.ownerId) &&
             data.month is string && data.month.matches('^[0-9]{4}-[0-9]{2}$') &&
             data.frequency in ['once', 'fixed', 'installments'] &&
             data.createdAt == request.time;
    }

    // --- ROUTES ---

    match /users/{userId} {
      allow read: if isSignedIn() && (
        isOwner(userId) || 
        (resource.data.coupleId != null && resource.data.coupleId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleId)
      );
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        // Action: Update Revenue or basic info
        incoming().diff(existing()).affectedKeys().hasOnly(['revenue', 'displayName', 'photoURL', 'coupleId'])
      );
    }

    match /couples/{coupleId} {
      allow read: if isMemberOfCouple(coupleId);
      allow create: if isSignedIn() && (incoming().user1 == request.auth.uid) && isValidCouple(incoming());
      allow update: if isMemberOfCouple(coupleId) && (
        // Action: Join Couple
        (existing().user2 == null && incoming().user2 == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['user2', 'updatedAt']) && incoming().updatedAt == request.time) ||
        // Action: General update
        (incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']) && incoming().updatedAt == request.time)
      );
    }

    match /couples/{coupleId}/transactions/{txId} {
      allow read: if isMemberOfCouple(coupleId);
      allow create: if isMemberOfCouple(coupleId) && isValidTransaction(incoming()) && incoming().ownerId == request.auth.uid;
      allow update, delete: if isMemberOfCouple(coupleId) && existing().ownerId == request.auth.uid;
    }
  }
}
