rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety DENY for everything else
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check couple membership by looking at the couple document
    function isMemberOfCouple(coupleId) {
      let couple = get(/databases/$(database)/documents/couples/$(coupleId)).data;
      return isSignedIn() && (couple.user1 == request.auth.uid || couple.user2 == request.auth.uid);
    }

    // --- USERS ---
    match /users/{userId} {
      // Allow reading own profile or partner's profile if in same couple
      allow read: if isSignedIn() && (
        userId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('coupleId', 'none') == resource.data.get('coupleId', 'none')
      );
      allow write: if isOwner(userId);
    }

    // --- COUPLES ---
    match /couples/{coupleId} {
      allow get: if isSignedIn(); // Critical: allow any signed in user to see if they're part of it
      allow list: if isSignedIn() && (
        resource.data.user1 == request.auth.uid || 
        resource.data.user2 == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.user1 == request.auth.uid || 
        resource.data.user2 == request.auth.uid ||
        resource.data.user2 == null // Allow joining
      );
      
      // --- SUBCOLLECTIONS ---
      match /transactions/{id} { allow read, write: if isMemberOfCouple(coupleId); }
      match /goals/{id} { allow read, write: if isMemberOfCouple(coupleId); }
      match /cards/{id} { allow read, write: if isMemberOfCouple(coupleId); }
      match /accounts/{id} { allow read, write: if isMemberOfCouple(coupleId); }
      match /categories/{id} { allow read, write: if isMemberOfCouple(coupleId); }
    }
  }
}
